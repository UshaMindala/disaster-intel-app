# Disaster Intelligence System — Environment Variables
# Copy this file to .env and fill in your values

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here    # optional: only for temporary STS credentials

AWS_ACCOUNT_ID=your_aws_account_id_here

S3_BUCKET_NAME=your-main-s3-bucket-name
S3_VECTOR_BUCKET_NAME=your-vector-s3-bucket-name
