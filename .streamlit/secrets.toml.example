# Streamlit Secrets Template
# On Streamlit Cloud: paste these key-value pairs into the "Secrets" editor
# in your app dashboard (Settings → Secrets).
# Locally: copy this file to .streamlit/secrets.toml and fill in real values.

AWS_DEFAULT_REGION    = "us-east-1"
AWS_ACCESS_KEY_ID     = "your_access_key_here"
AWS_SECRET_ACCESS_KEY = "your_secret_key_here"
AWS_SESSION_TOKEN     = ""          # leave blank if using long-term IAM credentials

AWS_ACCOUNT_ID        = "your_aws_account_id"

S3_BUCKET_NAME        = "your-main-s3-bucket-name"
S3_VECTOR_BUCKET_NAME = "your-vector-s3-bucket-name"
